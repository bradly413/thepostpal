{
  "name": "angie-social-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 8240",
    "build": "prisma generate && next build",
    "vercel-build": "bash scripts/vercel-build.sh",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:studio": "vitest run src/lib/studio src/app/api/studio src/app/api/generate-image/route.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:studio": "playwright test e2e/studio.spec.ts",
    "test:e2e:home": "playwright test e2e/home.spec.ts",
    "db:studio": "export $(grep -h '^DATABASE_URL=' .env.local | sed 's/\"//g') && prisma studio --port 5555 --browser none",
    "tokens:migrate:social": "export $(grep -h -E '^(DATABASE_URL|TOKEN_ENC_KEY)=' .env.local | sed 's/\"//g') && tsx scripts/migrate-social-account-tokens.ts",
    "seed:verticals": "tsx scripts/seed-verticals.ts",
    "addon:pro-images": "export $(grep -h '^DATABASE_URL=' .env.local | sed 's/\"//g') && tsx scripts/set-pro-images-addon.ts",
    "claude:sync": "bash scripts/generate-claude-catchup.sh",
    "remotion:studio": "remotion studio src/remotion/posterboy-slideshow/index.ts",
    "remotion:compositions": "remotion compositions src/remotion/posterboy-slideshow/index.ts",
    "remotion:render": "bash scripts/render-posterboy-slideshow.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@anthropic-ai/sdk": "^0.96.0",
    "@aws-sdk/client-s3": "^3.1058.0",
    "@aws-sdk/s3-request-presigner": "^3.1061.0",
    "@gsap/react": "^2.1.2",
    "@prisma/client": "^6.19.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@remotion/bundler": "4.0.464",
    "@remotion/cli": "4.0.464",
    "@remotion/media-utils": "4.0.464",
    "@remotion/player": "4.0.464",
    "@remotion/renderer": "4.0.464",
    "@sentry/nextjs": "^10.57.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.92",
    "@types/three": "^0.184.1",
    "@upstash/redis": "^1.38.0",
    "ai": "^6.0.196",
    "cookies-next": "^6.1.1",
    "date-fns": "^4.1.0",
    "gsap": "^3.15.0",
    "html-to-image": "^1.11.13",
    "jose": "^6.2.3",
    "lenis": "^1.3.23",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remotion": "4.0.464",
    "server-only": "^0.0.1",
    "stripe": "^17.7.0",
    "swiper": "^12.2.0",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
